# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_ENV=development
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Supabase PostgreSQL with pgvector)
DATABASE_URL=postgres://user:password@db.your-project.supabase.co:5432/postgres
SUPABASE_DB_URL=postgres://user:password@db.your-project.supabase.co:5432/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Redis (Upstash)
REDIS_URL=redis://default:your-password@your-endpoint.upstash.io:6379

# Google AI (Gemini + Embeddings)
GEMINI_API_KEY=your-gemini-api-key

# Jina AI (Reranker)
JINA_API_KEY=your-jina-api-key

# Observability
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
LANGSMITH_API_KEY=your-langsmith-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=documind

# CORS (production only, comma-separated origins)
CORS_ALLOWED_ORIGINS=https://documind.app
